{
  "name": "product-portal",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:a": "turbo dev --filter=@product-portal/project-a",
    "dev:b": "turbo dev --filter=@product-portal/project-b",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "turbo": "2.5.4",
    "prettier": "3.5.3",
    "typescript": "5.8.3"
  }
}
